{
  "extends": "@bfra.me/tsconfig",
  "compilerOptions": {
    "baseUrl": ".",
    "moduleResolution": "node",
    "paths": {
      "@/*": ["./*"]
    },
    "resolveJsonModule": true,
    "allowImportingTsExtensions": true,
    "noPropertyAccessFromIndexSignature": false,
    "noEmit": true
  },
  "include": [
    "scripts/**/*",
    "utils/**/*",
    "types/**/*",
    "eslint.config.ts",
    "__tests__/**/*",
    "vitest.config.ts",
    ".agents/skills/**/*"
  ],
  "exclude": ["node_modules", "dist"]
}
